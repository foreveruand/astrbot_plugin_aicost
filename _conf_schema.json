{
  "enable_daily_report": {
    "type": "bool",
    "default": false,
    "description": "启用每日定时报告"
  },
  "report_time": {
    "type": "string",
    "default": "08:00",
    "description": "每日报告时间 (HH:MM)"
  },
  "report_targets": {
    "type": "list",
    "default": [],
    "description": "报告发送目标列表",
    "items": {
      "type": "string"
    }
  },
  "report_style": {
    "type": "string",
    "default": "midnight",
    "description": "报告样式",
    "hint": "可选 midnight、paper、aurora，设置页可直接切换",
    "options": ["midnight", "paper", "aurora"]
  },
  "azure_tenant_id": {
    "type": "string",
    "default": "",
    "description": "Azure 租户 ID"
  },
  "azure_client_id": {
    "type": "string",
    "default": "",
    "description": "Azure 客户端 ID"
  },
  "azure_client_secret": {
    "type": "string",
    "default": "",
    "description": "Azure 客户端密钥"
  },
  "azure_subscription_id": {
    "type": "string",
    "default": "",
    "description": "Azure 订阅 ID"
  },
  "openrouter_api_key": {
    "type": "string",
    "default": "",
    "description": "OpenRouter API Key"
  },
  "google_project_id": {
    "type": "string",
    "default": "",
    "description": "Google Cloud 项目 ID"
  },
  "google_bq_table": {
    "type": "string",
    "default": "",
    "description": "BigQuery 账单表地址 (project.dataset.table)"
  },
  "google_service_account_json": {
    "type": "file",
    "default": [],
    "file_types": ["json"],
    "description": "Google 服务账号 JSON 文件"
  },
  "xai_api_key": {
    "type": "string",
    "default": "",
    "description": "xAI API Key"
  },
  "xai_team_id": {
    "type": "string",
    "default": "",
    "description": "xAI Team ID"
  },
  "t2i_image_type": {
    "type": "string",
    "default": "jpeg",
    "description": "报告图片格式",
    "hint": "jpeg 文件更小，png 支持透明背景",
    "options": ["jpeg", "png"]
  },
  "t2i_image_quality": {
    "type": "int",
    "default": 70,
    "description": "报告图片质量（仅 JPEG 格式有效）",
    "hint": "数值越高质量越好，文件越大。推荐 60-90",
    "min": 10,
    "max": 100
  },
  "t2i_scale": {
    "type": "string",
    "default": "device",
    "description": "页面缩放设置",
    "hint": "css = CSS像素对应设备分辨率（高分屏截图变小），device = 使用设备缩放设置",
    "options": ["css", "device"]
  },
  "t2i_full_page": {
    "type": "bool",
    "default": true,
    "description": "渲染完整页面；关闭时按报告内容高度裁切"
  }
}
