{
  "enable_daily_report": {
    "type": "bool",
    "default": false,
    "description": "启用每日定时报告"
  },
  "report_time": {
    "type": "string",
    "default": "08:00",
    "description": "每日报告时间 (HH:MM)"
  },
  "report_targets": {
    "type": "list",
    "default": [],
    "description": "报告发送目标列表",
    "items": {
      "type": "string"
    }
  },
  "report_style": {
    "type": "string",
    "default": "midnight",
    "description": "报告样式",
    "hint": "可选 midnight、paper、aurora，设置页可直接切换",
    "options": ["midnight", "paper", "aurora"]
  },
  "report_scale": {
    "type": "int",
    "default": 2,
    "description": "图片渲染倍率",
    "hint": "值越大图片越清晰，体积也越大，推荐 2 或 3"
  },
  "report_font_file": {
    "type": "file",
    "default": [],
    "file_types": ["ttf", "otf", "ttc"],
    "description": "自定义报告字体文件"
  },
  "azure_tenant_id": {
    "type": "string",
    "default": "",
    "description": "Azure 租户 ID"
  },
  "azure_client_id": {
    "type": "string",
    "default": "",
    "description": "Azure 客户端 ID"
  },
  "azure_client_secret": {
    "type": "string",
    "default": "",
    "description": "Azure 客户端密钥"
  },
  "azure_subscription_id": {
    "type": "string",
    "default": "",
    "description": "Azure 订阅 ID"
  },
  "openrouter_api_key": {
    "type": "string",
    "default": "",
    "description": "OpenRouter API Key"
  },
  "google_project_id": {
    "type": "string",
    "default": "",
    "description": "Google Cloud 项目 ID"
  },
  "google_bq_table": {
    "type": "string",
    "default": "",
    "description": "BigQuery 账单表地址 (project.dataset.table)"
  },
  "google_service_account_json": {
    "type": "file",
    "default": [],
    "file_types": ["json"],
    "description": "Google 服务账号 JSON 文件"
  },
  "xai_api_key": {
    "type": "string",
    "default": "",
    "description": "xAI API Key"
  },
  "xai_team_id": {
    "type": "string",
    "default": "",
    "description": "xAI Team ID"
  }
}
